{
  "name": "ar-terminal",
  "displayName": "RTL Terminal",
  "description": "RTL-aware terminal with Arabic text shaping and BiDi support for VS Code",
  "version": "0.3.1",
  "publisher": "khalid-alzahrani",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alzahrani-khalid/ar-terminal"
  },
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "arabic",
    "hebrew",
    "persian",
    "urdu",
    "rtl",
    "right-to-left",
    "bidi",
    "terminal",
    "unicode",
    "claude"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "rtlTerminal.newTerminal",
        "title": "RTL Terminal: New Terminal",
        "icon": {
          "light": "media/sidebar-icon-light.svg",
          "dark": "media/sidebar-icon-dark.svg"
        }
      },
      {
        "command": "rtlTerminal.toggleMode",
        "title": "RTL Terminal: Toggle Mode"
      },
      {
        "command": "rtlTerminal.setModeOn",
        "title": "RTL Terminal: Set Mode On"
      },
      {
        "command": "rtlTerminal.setModeOff",
        "title": "RTL Terminal: Set Mode Off"
      },
      {
        "command": "rtlTerminal.setModeAuto",
        "title": "RTL Terminal: Set Mode Auto"
      }
    ],
    "terminal": {
      "profiles": [
        {
          "id": "rtlTerminal.rtlTerminal",
          "title": "RTL Terminal",
          "icon": "terminal"
        }
      ]
    },
    "keybindings": [
      {
        "command": "rtlTerminal.newTerminal",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "rtlTerminal",
          "title": "RTL Terminal",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "rtlTerminal": [
        {
          "id": "rtlTerminal.welcome",
          "name": "RTL Terminal"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "rtlTerminal.welcome",
        "contents": "Open an RTL-aware terminal with Arabic text support.\n[Open RTL Terminal](command:rtlTerminal.newTerminal)\nShortcut: Cmd+Shift+T"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "rtlTerminal.newTerminal",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "RTL Terminal",
      "properties": {
        "rtlTerminal.mode": {
          "type": "string",
          "enum": [
            "auto",
            "on",
            "off"
          ],
          "default": "auto",
          "description": "RTL processing mode."
        },
        "rtlTerminal.shell": {
          "type": "string",
          "default": "",
          "description": "Shell executable path. Empty uses VS Code default."
        },
        "rtlTerminal.shellArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Shell arguments."
        },
        "rtlTerminal.reshapeInput": {
          "type": "boolean",
          "default": true,
          "description": "Reshape Arabic text as you type."
        },
        "rtlTerminal.logLevel": {
          "type": "string",
          "enum": [
            "off",
            "error",
            "warn",
            "info",
            "debug"
          ],
          "default": "off",
          "description": "Log level."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.mjs --production",
    "watch": "node esbuild.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "bidi-js": "^1.0.3",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.95.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
